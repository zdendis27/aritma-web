{
  "name": "aritma-web",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "database"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm run build --workspaces",
    "seed": "npm --workspace database run seed",
    "prisma:generate": "npm --workspace database run prisma:generate",
    "prisma:migrate": "npm --workspace database run prisma:migrate"
  }
}
